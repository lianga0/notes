 12px, rgba(60, 64, 67, 0.3) 0px 4px 4px; }

html { height: 100%; }

.toprow { width: 100%; display: table; height: 24px; background-color: rgb(=
255, 255, 255); }

.btn { display: table; transition: opacity 1s, background 0.75s; background=
: transparent; color: rgb(255, 255, 255); }

.btn > div { display: table-cell; vertical-align: middle; }

.skip { opacity: 0.95; padding: 12px 12px 0px; float: right; }

.skip svg { height: 1.5em; width: 1.5em; margin-left: -0.5em; margin-right:=
